# Forge Core Configuration

# Server
HOST=0.0.0.0
PORT=3000
ENVIRONMENT=development
LOG_LEVEL=debug

# Database (optional)
# DATABASE_URL=postgresql://user:password@localhost/forge_core

# Redis (optional)
# REDIS_URL=redis://localhost:6379

# Execution
MAX_QUEUE_SIZE=10000
WORKER_THREADS=4
REQUEST_TIMEOUT_SECONDS=30

# Agent Configuration
AGENT_DEFAULT_TEMPERATURE=0.7
AGENT_DEFAULT_MAX_TOKENS=2048
AGENT_DEFAULT_TIMEOUT=30

# Logging
RUST_LOG=forge_core=debug,axum=info,tokio=info
